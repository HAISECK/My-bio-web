  <!-- PHOTO -->
  <div class="card reveal" style="text-align:center;">
    <img src="bio/IMG_20260626_194905_548.jpg" alt="Photo" class="profile-photo">
  </div>

  <!-- PLAY TOGETHER -->
  <div class="card reveal">
    <div class="section-label">let's play together</div>
    <p style="font-size:11px;color:#444;margin-bottom:16px;font-family:var(--mono);">// click any nickname or ID to copy</p>
