<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HAISECK ✦</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #000000;
    --card: #0d0d0d;
    --card2: #141414;
    --border: #1f1f1f;
    --purple: #9b59f5;
    --purple-dim: rgba(155,89,245,0.15);
    --crimson: #e0294a;
    --crimson-dim: rgba(224,41,74,0.12);
    --white: #f0f0f0;
    --muted: #666;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Inter', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.7;
    min-height: 100vh;
  }

  .container {
    max-width: 650px;
    margin: 0 auto;
    padding: 48px 20px 80px;
  }

  /* ── HERO VIDEO ── */
  .hero-wrap {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    margin-bottom: 28px;
    box-shadow: 0 0 40px rgba(155,89,245,0.25), 0 0 80px rgba(155,89,245,0.08);
  }
  .hero-wrap video {
    width: 100%;
    display: block;
    border-radius: 16px;
  }

  /* ── HEADER ── */
  .header {
    text-align: center;
    margin-bottom: 32px;
    animation: fadeUp 0.6s ease both;
  }
  .header h1 {
    font-family: var(--mono);
    font-size: clamp(22px, 5vw, 30px);
    font-weight: 700;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, #fff 30%, var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 6px;
  }
  .header a {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--purple);
    text-decoration: none;
    border-bottom: 1px solid rgba(155,89,245,0.3);
    transition: color 0.2s, border-color 0.2s;
  }
  .header a:hover { color: #fff; border-color: #fff; }

  /* ── CARDS ── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 16px;
    animation: fadeUp 0.5s ease both;
  }
  .card + .card { animation-delay: 0.05s; }

  .section-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── ABOUT ── */
  .about-row {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
    align-items: baseline;
  }
  .about-key {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    min-width: 90px;
    flex-shrink: 0;
  }
  .about-val { color: var(--white); font-size: 13px; }
  .about-note {
    font-size: 11px;
    color: #444;
    font-style: italic;
    margin-top: -4px;
    margin-bottom: 8px;
    padding-left: 98px;
  }
  .tag-list { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    font-family: var(--mono);
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--card2);
    border: 1px solid var(--border);
    color: #aaa;
  }
  .pronouns-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 10px;
    padding: 2px 10px;
    border-radius: 20px;
    border: 1px solid var(--crimson);
    color: var(--crimson);
    background: var(--crimson-dim);
    letter-spacing: 0.08em;
  }

  /* ── SECTION GIF ── */
  .section-gif {
    width: 100%;
    border-radius: 14px;
    display: block;
    margin-bottom: 16px;
    border: 1px solid var(--border);
    box-shadow: 0 0 24px rgba(155,89,245,0.12);
  }

  /* ── KINN ── */
  .kinn-list { list-style: none; }
  .kinn-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 0;
    border-bottom: 1px solid #111;
    font-size: 13px;
  }
  .kinn-list li:last-child { border-bottom: none; }
  .kinn-num {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--purple);
    min-width: 18px;
    opacity: 0.7;
  }

  /* ── ANIME GRID ── */
  .sub-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 10px;
    margin-top: 20px;
  }
  .anime-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    gap: 6px;
    margin-bottom: 4px;
  }
  .anime-item {
    font-size: 12px;
    padding: 6px 10px;
    background: var(--card2);
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    color: #ccc;
    display: flex;
    gap: 6px;
    align-items: baseline;
    transition: border-color 0.2s, color 0.2s;
  }
  .anime-item:hover { border-color: var(--purple); color: #fff; }
  .anime-item .n {
    font-family: var(--mono);
    font-size: 9px;
    color: #444;
    flex-shrink: 0;
  }
  .media-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .media-pill {
    font-size: 12px;
    padding: 4px 10px;
    background: var(--card2);
    border: 1px solid #1a1a1a;
    border-radius: 20px;
    color: #bbb;
  }
  .doza-note {
    font-family: var(--mono);
    font-size: 11px;
    color: #333;
    font-style: italic;
    margin-top: 12px;
  }

  /* ── PHOTO ── */
  .profile-photo {
    width: 100%;
    max-width: 280px;
    display: block;
    margin: 0 auto 16px;
    border-radius: 50%;
    border: 2px solid var(--border);
    box-shadow: 0 0 32px rgba(155,89,245,0.2);
    aspect-ratio: 1;
    object-fit: cover;
  }

  /* ── PLAY TOGETHER ── */
  .play-list { list-style: none; }
  .play-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid #111;
  }
  .play-row:last-child { border-bottom: none; }
  .play-game {
    font-size: 12px;
    color: var(--muted);
    min-width: 160px;
  }
  .copyable {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--white);
    cursor: pointer;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid transparent;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
    position: relative;
    user-select: none;
  }
  .copyable:hover {
    border-color: var(--purple);
    background: var(--purple-dim);
    color: #d4b8ff;
  }
  .copyable:active { transform: scale(0.97); }

  .play-cta {
    text-align: center;
    margin-top: 20px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--purple);
    letter-spacing: 0.06em;
    padding: 12px;
    border: 1px dashed rgba(155,89,245,0.3);
    border-radius: 10px;
  }

  /* ── TOAST ── */
  .toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #1a1a1a;
    border: 1px solid var(--purple);
    color: var(--purple);
    font-family: var(--mono);
    font-size: 12px;
    padding: 8px 20px;
    border-radius: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 999;
    white-space: nowrap;
    box-shadow: 0 0 20px rgba(155,89,245,0.3);
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 480px) {
    .anime-grid { grid-template-columns: 1fr 1fr; }
    .about-note { padding-left: 0; }
    .play-game { min-width: 120px; font-size: 11px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal, .card { animation: none; transition: none; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- VIDEO HERO -->
  <div class="hero-wrap reveal">
